# Congress.gov API — free at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_key_here

# FEC — optional, DEMO_KEY works for low traffic
# Get a real key at https://api.data.gov/signup/
FEC_API_KEY=DEMO_KEY

# Allowed CORS origins. Use * for dev, your frontend URL for prod.
ALLOWED_ORIGINS=http://localhost:5173
